generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── USERS ──────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  firstName     String?
  lastName      String?
  phone         String?
  avatarUrl     String?
  role          UserRole
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  office        Office?
  provider      Provider?
}

enum UserRole {
  OFFICE
  PROVIDER
  ADMIN
}

// ── OFFICE ─────────────────────────────────────────
model Office {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  name            String
  phone           String?
  address         String?
  city            String?
  state           String?
  zip             String?
  specialty       String?
  software        String[]
  bio             String?
  plan            String?
  hiringRoles     String[]
  logoUrl         String?
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shifts          Shift[]
  bookings        Booking[]
  reviews         Review[]
  savedProviders  SavedProvider[]
  messages        Message[]
}

// ── PROVIDER ───────────────────────────────────────
model Provider {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  role              String
  licenseNumber     String?
  licenseState      String?
  licenseExpiry     DateTime?
  bio               String?
  hourlyRate        Float?
  travelRadius      Int?
  city              String?
  state             String?
  zip               String?
  software          String[]
  skills            String[]
  resumeUrl         String?
  resumeName        String?
  reliabilityScore  Float    @default(100)
  verified          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  availability      Availability[]
  bookings          Booking[]
  applications      Application[]
  reviews           Review[]
  savedOffices      SavedOffice[]
  messages          Message[]
  credentials       Credential[]
}

// ── CREDENTIALS ────────────────────────────────────
model Credential {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  type        String
  fileUrl     String?
  expiresAt   DateTime?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ── AVAILABILITY ───────────────────────────────────
model Availability {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  dayOfWeek   Int?
  date        DateTime?
  startTime   String
  endTime     String
  isException Boolean  @default(false)
  note        String?
  createdAt   DateTime @default(now())
}

// ── SHIFTS ─────────────────────────────────────────
model Shift {
  id           String      @id @default(cuid())
  officeId     String
  office       Office      @relation(fields: [officeId], references: [id])
  role         String
  jobType      String      @default("TEMPORARY")
  date         DateTime
  startTime    String
  endTime      String
  hourlyRate   Float
  description  String?
  software     String[]
  schedule     String?
  benefits     String[]
  experienceYr Int?
  salaryMin    Float?
  salaryMax    Float?
  status       ShiftStatus @default(OPEN)
  isRapidFill  Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  applications Application[]
  booking      Booking?
}

enum ShiftStatus {
  OPEN
  FILLED
  CANCELLED
  COMPLETED
}

// ── APPLICATIONS ───────────────────────────────────
model Application {
  id          String            @id @default(cuid())
  shiftId     String
  shift       Shift             @relation(fields: [shiftId], references: [id])
  providerId  String
  provider    Provider          @relation(fields: [providerId], references: [id])
  status      ApplicationStatus @default(PENDING)
  note        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

// ── BOOKINGS ───────────────────────────────────────
model Booking {
  id          String        @id @default(cuid())
  shiftId     String        @unique
  shift       Shift         @relation(fields: [shiftId], references: [id])
  officeId    String
  office      Office        @relation(fields: [officeId], references: [id])
  providerId  String
  provider    Provider      @relation(fields: [providerId], references: [id])
  status      BookingStatus @default(CONFIRMED)
  cancelledBy String?
  cancelNote  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reviews     Review[]
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ── REVIEWS ────────────────────────────────────────
model Review {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  officeId    String
  office      Office   @relation(fields: [officeId], references: [id])
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  rating      Int
  comment     String?
  tags        String[]
  createdAt   DateTime @default(now())
}

// ── MESSAGES ───────────────────────────────────────
model Message {
  id          String   @id @default(cuid())
  officeId    String
  office      Office   @relation(fields: [officeId], references: [id])
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  fromRole    UserRole
  body        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ── SAVED ──────────────────────────────────────────
model SavedProvider {
  id         String   @id @default(cuid())
  officeId   String
  office     Office   @relation(fields: [officeId], references: [id])
  providerId String
  createdAt  DateTime @default(now())

  @@unique([officeId, providerId])
}

model SavedOffice {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  officeId   String
  createdAt  DateTime @default(now())

  @@unique([providerId, officeId])
}

// ── NOTIFICATIONS ──────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}